# Plantilla de variables de entorno. Copiar a .env y completar.
# En Railway, definir estas variables en el panel del servicio.

# --- Comunes ---
SECRET_KEY=cambia-esto-por-una-clave-secreta
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# JWT
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=1

# API
PAGE_SIZE=20

# --- Producción (Railway) ---
# Seleccionar settings de producción:
# DJANGO_SETTINGS_MODULE=config.settings.prod
# Base de datos PostgreSQL (la provee Railway):
# DATABASE_URL=postgresql://user:password@host:port/dbname
# Dominios del servicio (CSRF):
# CSRF_TRUSTED_ORIGINS=https://tu-app.up.railway.app
# Redirección HTTPS (Railway ya hace TLS termination):
# SECURE_SSL_REDIRECT=True
